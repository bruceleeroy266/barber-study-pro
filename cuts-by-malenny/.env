# Environment Configuration

# Node Environment
NODE_ENV=production
PORT=3000

# Supabase Database (Production)
SUPABASE_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.abcdefgh12345678.supabase.co:5432/postgres

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-to-something-random

# Frontend URL (update after deploying frontend)
FRONTEND_URL=https://your-frontend-url.vercel.app

# Stripe Configuration (optional - for payments later)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Twilio Configuration (optional - for SMS later)
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+14059850600
