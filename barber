let currentQ = 0;
let score = 0;
let selectedQuestions = [];
let userAnswers = [];
let timeLeft = 7200;
let timer;

function checkAuth() {
    const sessionData = localStorage.getItem('bsp_session');
    if(sessionData) {
        try {
            const session = JSON.parse(sessionData);
            if(session.email) {
                document.getElementById('authGate').style.display='none';
                document.getElementById('protectedContent').classList.add('show');
            }
        } catch(e) {
            console.error('Invalid session data');
        }
    }
}
checkAuth();

function fisherYatesShuffle(array) {
    const arr = [...array];
    for(let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
}

function startExam() {
    selectedQuestions = fisherYatesShuffle(fullQuestionBank).slice(0, 150);
    userAnswers = new Array(selectedQuestions.length).fill(null);
    
    document.getElementById('startScreen').style.display='none';
    document.getElementById('quizContainer').style.display='block';
    
    createNavGrid();
    showQuestion();
    
    timer = setInterval(() => {
        timeLeft--;
        const m = Math.floor(timeLeft/60), s = timeLeft%60;
        const timerEl = document.getElementById('timer');
        timerEl.textContent = `${m}:${s.toString().padStart(2,'0')}`;
        if(timeLeft <= 600) timerEl.classList.add('warning');
        if(timeLeft <= 0) submitExam();
    }, 1000);
}

function createNavGrid() {
    const grid = document.getElementById('navGrid');
    grid.innerHTML = '';
    for(let i = 0; i < selectedQuestions.length; i++) {
        const div = document.createElement('div');
        div.className = 'nav-item';
        div.textContent = i + 1;
        div.onclick = () => goToQuestion(i);
        div.id = `nav-${i}`;
        grid.appendChild(div);
    }
}

function goToQuestion(idx) {
    currentQ = idx;
    showQuestion();
}

function showQuestion() {
