# Supabase configuration
# Get these values from Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Optional: enable demo mode when Supabase is not configured
# NEXT_PUBLIC_DEMO_MODE=true

# Admin seeding (used only by scripts/create-admin-user.ts)
# NEVER expose the service role key or admin password in source code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
ASCYN_ADMIN_EMAIL=admin@example.com
ASCYN_ADMIN_PASSWORD=change-this-to-a-strong-password
ASCYN_ADMIN_FULL_NAME="ASCYN PRO Administrator"

# Resend transactional email configuration
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@ascynpro.com
NOTIFICATION_FROM_EMAIL=notifications@ascynpro.com
EMAIL_TO=hello@ascynpro.com
